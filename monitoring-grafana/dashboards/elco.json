      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "ha-postgres"
          },
          "rawSql": "SELECT TO_TIMESTAMP(s.start_ts) AS time, s.state AS \"Total\" FROM statistics s JOIN statistics_meta sm ON s.metadata_id = sm.id WHERE sm.statistic_id = 'sensor.elco_heating_cost_total' AND $__unixEpochFilter(s.start_ts) ORDER BY s.start_ts"

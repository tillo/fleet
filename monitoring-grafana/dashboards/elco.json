    {
      "id": 5,
      "type": "timeseries",
      "title": "Outside temp vs heating power",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "ha-postgres"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 5,
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Outside \u00b0C"
            },
            "properties": [
              {
                "id": "unit",
                "value": "celsius"
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#5bc0de"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Heating W"
            },
            "properties": [
              {
                "id": "unit",
                "value": "watt"
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#d9534f"
                }
              },
              {
                "id": "custom.fillOpacity",
                "value": 15
              },
              {
                "id": "custom.axisPlacement",
                "value": "right"
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "showLegend": true,
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "ha-postgres"
          },
          "rawSql": "SELECT TO_TIMESTAMP(s.start_ts) AS time, s.mean AS \"Outside \u00b0C\" FROM statistics s JOIN statistics_meta sm ON s.metadata_id = sm.id WHERE sm.statistic_id = 'sensor.elco_outside_temp_24h_avg' AND $__unixEpochFilter(s.start_ts) ORDER BY s.start_ts"
        },
        {
          "refId": "B",
          "format": "time_series",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "ha-postgres"
          },
          "rawSql": "SELECT TO_TIMESTAMP(s.start_ts) AS time, s.mean AS \"Heating W\" FROM statistics s JOIN statistics_meta sm ON s.metadata_id = sm.id WHERE sm.statistic_id = 'sensor.elco_heating_power' AND $__unixEpochFilter(s.start_ts) ORDER BY s.start_ts"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Daily heating + DHW hours",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "ha-postgres"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 14
      },
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "min": 0,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 0,
            "barAlignment": 0
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Heating"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#d9534f"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "DHW"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#f0ad4e"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "showLegend": true,
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "ha-postgres"
          },
          "rawSql": "SELECT date_trunc('day', TO_TIMESTAMP(s.start_ts)) AS time, MAX(s.max) AS \"Heating\" FROM statistics s JOIN statistics_meta sm ON s.metadata_id = sm.id WHERE sm.statistic_id = 'sensor.elco_heating_active_today' AND $__unixEpochFilter(s.start_ts) GROUP BY 1 ORDER BY 1"
        },
        {
          "refId": "B",
          "format": "time_series",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "ha-postgres"
          },
          "rawSql": "SELECT date_trunc('day', TO_TIMESTAMP(s.start_ts)) AS time, MAX(s.max) AS \"DHW\" FROM statistics s JOIN statistics_meta sm ON s.metadata_id = sm.id WHERE sm.statistic_id = 'sensor.elco_dhw_enabled_today' AND $__unixEpochFilter(s.start_ts) GROUP BY 1 ORDER BY 1"
        }
      ]
    },

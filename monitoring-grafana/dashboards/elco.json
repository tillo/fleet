{
  "title": "ELCO \u2014 heating & DHW",
  "uid": "mdapi-elco",
  "tags": [
    "mdapi",
    "ha",
    "elco",
    "heating"
  ],
  "schemaVersion": 40,
  "timezone": "Europe/Zurich",
  "refresh": "5m",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "editable": true,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Outside (24h avg)",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "ha-postgres"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              },
              {
                "color": "green",
                "value": 10
              },
              {
                "color": "yellow",
                "value": 18
              },
              {
                "color": "red",
                "value": 25
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "ha-postgres"
          },
          "rawSql": "SELECT TO_TIMESTAMP(s.last_updated_ts) AS time, s.state::float AS value FROM states s JOIN states_meta sm ON s.metadata_id = sm.metadata_id WHERE sm.entity_id = 'sensor.elco_outside_temp_24h_avg' AND s.state ~ '^-?[0-9.]+$' ORDER BY s.last_updated_ts DESC LIMIT 1"
        }
      ]
    },
    {

{
  "title": "Solar \u2014 production & consumption",
  "uid": "mdapi-solar",
  "tags": [
    "mdapi",
    "ha",
    "solar",
    "energy"
  ],
  "schemaVersion": 40,
  "timezone": "Europe/Zurich",
  "refresh": "5m",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "editable": true,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Production now",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "ha-postgres"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1000
              },
              {
                "color": "green",
                "value": 3000
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "ha-postgres"
          },
          "rawSql": "SELECT TO_TIMESTAMP(s.last_updated_ts) AS time, s.state::float AS value FROM states s JOIN states_meta sm ON s.metadata_id = sm.metadata_id WHERE sm.entity_id = 'sensor.power_production_now' AND s.state ~ '^-?[0-9.]+$' ORDER BY s.last_updated_ts DESC LIMIT 1"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Produced today",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "ha-postgres"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "kwatth",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "green",
                "value": 15
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "ha-postgres"
          },
          "rawSql": "SELECT TO_TIMESTAMP(s.last_updated_ts) AS time, s.state::float AS value FROM states s JOIN states_meta sm ON s.metadata_id = sm.metadata_id WHERE sm.entity_id = 'sensor.solar_panel_production_daily' AND s.state ~ '^[0-9.]+$' ORDER BY s.last_updated_ts DESC LIMIT 1"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Consumed today",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "ha-postgres"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "kwatth",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 20
              },
              {
                "color": "red",
                "value": 40
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "ha-postgres"
          },
          "rawSql": "SELECT TO_TIMESTAMP(s.last_updated_ts) AS time, s.state::float AS value FROM states s JOIN states_meta sm ON s.metadata_id = sm.metadata_id WHERE sm.entity_id = 'sensor.solar_house_consumption_daily' AND s.state ~ '^[0-9.]+$' ORDER BY s.last_updated_ts DESC LIMIT 1"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Net cost today",
      "description": "Cost of imported energy minus compensation for exported. Negative = solar paid for itself today.",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "ha-postgres"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyCHF",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "ha-postgres"
          },
          "rawSql": "WITH ic AS (SELECT s.state::float v FROM states s JOIN states_meta sm ON s.metadata_id = sm.metadata_id WHERE sm.entity_id = 'sensor.solar_imported_power_kwh_cost' AND s.state ~ '^[0-9.]+$' ORDER BY s.last_updated_ts DESC LIMIT 1), ec AS (SELECT s.state::float v FROM states s JOIN states_meta sm ON s.metadata_id = sm.metadata_id WHERE sm.entity_id = 'sensor.solar_exported_power_kwh_compensation' AND s.state ~ '^[0-9.]+$' ORDER BY s.last_updated_ts DESC LIMIT 1) SELECT NOW() AS time, (ic.v - ec.v) AS value FROM ic, ec"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Power flow",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "ha-postgres"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Production"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#f0ad4e"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "House consumption"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#5bc0de"
                }
              },
              {
                "id": "custom.fillOpacity",
                "value": 5
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Rack"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#999999"
                }
              },
              {
                "id": "custom.fillOpacity",
                "value": 0
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "showLegend": true,
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "ha-postgres"
          },
          "rawSql": "SELECT TO_TIMESTAMP(s.start_ts) AS time, s.mean AS \"Production\" FROM statistics s JOIN statistics_meta sm ON s.metadata_id = sm.id WHERE sm.statistic_id = 'sensor.power_production_now' AND $__unixEpochFilter(s.start_ts) ORDER BY s.start_ts"
        },
        {
          "refId": "C",
          "format": "time_series",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "ha-postgres"
          },
          "rawSql": "SELECT TO_TIMESTAMP(s.start_ts) AS time, s.mean AS \"Rack\" FROM statistics s JOIN statistics_meta sm ON s.metadata_id = sm.id WHERE sm.statistic_id = 'sensor.rack_power' AND $__unixEpochFilter(s.start_ts) ORDER BY s.start_ts"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Daily energy (production \u00b7 import \u00b7 export)",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "ha-postgres"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "fieldConfig": {
        "defaults": {
          "unit": "kwatth",
          "min": 0,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 2,
            "lineInterpolation": "stepAfter"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Production"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#f0ad4e"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Imported"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#d9534f"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Exported"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#5cb85c"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "showLegend": true,
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "ha-postgres"
          },
          "rawSql": "SELECT date_trunc('day', TO_TIMESTAMP(s.start_ts)) AS time, MAX(s.state) AS \"Production\" FROM statistics s JOIN statistics_meta sm ON s.metadata_id = sm.id WHERE sm.statistic_id = 'sensor.solar_panel_production_daily' AND $__unixEpochFilter(s.start_ts) GROUP BY 1 ORDER BY 1"
        },
        {
          "refId": "B",
          "format": "time_series",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "ha-postgres"
          },
          "rawSql": "SELECT date_trunc('day', TO_TIMESTAMP(s.start_ts)) AS time, MAX(s.state) AS \"Imported\" FROM statistics s JOIN statistics_meta sm ON s.metadata_id = sm.id WHERE sm.statistic_id = 'sensor.solar_imported_power_daily' AND $__unixEpochFilter(s.start_ts) GROUP BY 1 ORDER BY 1"
        },
        {
          "refId": "C",
          "format": "time_series",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "ha-postgres"
          },
          "rawSql": "SELECT date_trunc('day', TO_TIMESTAMP(s.start_ts)) AS time, MAX(s.state) AS \"Exported\" FROM statistics s JOIN statistics_meta sm ON s.metadata_id = sm.id WHERE sm.statistic_id = 'sensor.solar_exported_power_daily' AND $__unixEpochFilter(s.start_ts) GROUP BY 1 ORDER BY 1"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Cost / compensation (cumulative)",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "ha-postgres"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyCHF",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Imported cost"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#d9534f"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Export compensation"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#5cb85c"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "showLegend": true,
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "ha-postgres"
          },
          "rawSql": "SELECT TO_TIMESTAMP(s.start_ts) AS time, s.state AS \"Imported cost\" FROM statistics s JOIN statistics_meta sm ON s.metadata_id = sm.id WHERE sm.statistic_id = 'sensor.solar_imported_power_kwh_cost' AND $__unixEpochFilter(s.start_ts) ORDER BY s.start_ts"
        },
        {
          "refId": "B",
          "format": "time_series",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "ha-postgres"
          },
          "rawSql": "SELECT TO_TIMESTAMP(s.start_ts) AS time, s.state AS \"Export compensation\" FROM statistics s JOIN statistics_meta sm ON s.metadata_id = sm.id WHERE sm.statistic_id = 'sensor.solar_exported_power_kwh_compensation' AND $__unixEpochFilter(s.start_ts) ORDER BY s.start_ts"
        }
      ]
    }
  ]
}
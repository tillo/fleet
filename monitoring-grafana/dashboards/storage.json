  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Capacity \u2014 FusionIO & P420i",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "FusionIO fullness by node",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-rancher"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-rancher"
          },
          "expr": "100 * longhorn_disk_usage_bytes{disk=\"fio-hot\"} / longhorn_disk_capacity_bytes{disk=\"fio-hot\"}",
          "legendFormat": "{{node}}",
          "refId": "A",
          "instant": false,
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 75
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      }
    },
